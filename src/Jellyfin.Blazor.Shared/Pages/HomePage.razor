@page "/"
@layout MainLayout

<Row>
    <Column>
        @if (_continueWatching is null)
        {
            <LoadingComponent/>
        }
        else if (_continueWatching.Count != 0)
        {
            <Row>
                <Heading Size="HeadingSize.Is2" TextColor="TextColor.White50">
                    Continue Watching
                </Heading>
            </Row>
            <Row>
                @foreach (var item in _continueWatching)
                {
                    <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                        <PrimaryCardComponent Item="item"/>
                    </Column>
                }

            </Row>
        }

        @if (_nextUp is null)
        {
            <LoadingComponent/>
        }
        else if (_nextUp.Count != 0)
        {
            <Row>
                <Heading Size="HeadingSize.Is2" TextColor="TextColor.White">
                    Next Up
                </Heading>
            </Row>
            <Row>
                @foreach (var item in _nextUp)
                {
                    <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                        <PrimaryCardComponent Item="item"/>
                    </Column>
                }
            </Row>
        }

        @if (_libraries is null)
        {
            <LoadingComponent/>
        }
        else if (_libraries.Length != 0)
        {
            foreach (var (library, items) in _libraries)
            {
                if (items is null)
                {
                    <LoadingComponent/>
                }
                else if (items.Count != 0)
                {
                    <Row>
                        <Heading Size="HeadingSize.Is2" TextColor="TextColor.White">
                            @library.Name
                        </Heading>
                    </Row>
                    <Row>
                        @foreach (var item in items)
                        {
                            <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                                <PrimaryCardComponent Item="item"/>
                            </Column>
                        }
                    </Row>
                }
            }
        }
    </Column>
</Row>
