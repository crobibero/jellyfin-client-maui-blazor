@page "/"
@layout MainLayout

<Row>
    <Column ColumnSize="ColumnSize.Is12">
        @if (_continueWatching is null)
        {
            <LoadingComponent/>
        }
        else if (_continueWatching.Count != 0)
        {
            <Row>
                <Heading Size="HeadingSize.Is2">Continue Watching</Heading>
            </Row>
            <Row>
                <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                    @foreach (var item in _continueWatching)
                    {
                        <PrimaryCardComponent Item="item"/>
                    }
                </Column>
            </Row>
        }

        @if (_nextUp is null)
        {
            <LoadingComponent/>
        }
        else if (_nextUp.Count != 0)
        {
            <Row>
                <Heading Size="HeadingSize.Is2">Next Up</Heading>
            </Row>
            <Row>
                <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                    @foreach (var item in _nextUp)
                    {
                        <PrimaryCardComponent Item="item"/>
                    }
                </Column>
            </Row>
        }

        @if (_libraries is null)
        {
            <LoadingComponent/>
        }
        else if (_libraries.Length != 0)
        {
            foreach (var (library, items) in _libraries)
            {
                if (items is null)
                {
                    <LoadingComponent/>
                }
                else if (items.Count != 0)
                {
                    <Row>
                        <Heading Size="HeadingSize.Is2">@library.Name</Heading>
                    </Row>
                    <Row>
                        <Column ColumnSize="ColumnSize.Is3.OnMobile.Is4.OnTablet.Is6.OnWidescreen">
                            @foreach (var item in items)
                            {
                                <PrimaryCardComponent Item="item"/>
                            }
                        </Column>
                    </Row>
                }
            }
        }
    </Column>
</Row>
