@page "/library/{libraryId:guid}"
@layout MainLayout

<Heading Size="HeadingSize.Is1">
    @_library?.Name
</Heading>

@if (_loading)
{
    <LoadingComponent/>
}
else
{
    foreach (var item in _items)
    {
        <Column ColumnSize="ColumnSize.Is2.Is3.OnTablet.Is4.OnWidescreen.Is6.OnFullHD">
            <PrimaryCardComponent Item="item"/>
        </Column>
    }

    <PagerComponent
        CurrentPage="@_pageIndex"
        PageCount="@_pageCount"
        OnPageChanged="@OnPageChangedAsync"/>
}
