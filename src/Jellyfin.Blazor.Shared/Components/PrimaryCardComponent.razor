<Figure @onclick="ViewItem" class="is-clickable">
    <FigureImage Source="@_imageUrl"/>
    <FigureCaption>
        <Div TextAlignment="TextAlignment.Center">
            @(ShowParentName ? _title : _subTitle)
        </Div>
        @if (ShowParentName)
        {
            <Div TextAlignment="TextAlignment.Center">
                @_subTitle
            </Div>
        }
    </FigureCaption>
</Figure>
